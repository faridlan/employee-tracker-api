                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Pencapaian berhasil dicatat",
                        "schema": {
                            "$ref": "#/definitions/github_com_faridlan_employee-tracker-api_internal_utils.SuccessResponse-github_com_faridlan_employee-tracker-api_internal_utils_EmptyObj"
